generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(USER)
  currencyCode  String    @default("USD")
  brandProfile  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  pages         Page[]
  subscription  Subscription?
  notificationEvents NotificationEvent[]
  teamProjectMembers TeamProjectMember[]
}

enum UserRole {
  USER
  ADMIN
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan   @default(STARTER)
  status        SubscriptionStatus @default(ACTIVE)
  paystackId    String?            @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

enum SubscriptionPlan {
  STARTER
  CREATOR
  STUDIO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

model Page {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  handle      String       @unique
  title       String?
  description String?
  isPublic    Boolean      @default(false)
  category    PageCategory @default(GENERIC)
  theme       Json?        // Stores CSS Variables/Tokens for this page
  clientEmail String?      // For notifications
  clientName  String?
  clientAccessTokenHash String?
  clientAccessCreatedAt DateTime?
  clientAccessRevoked Boolean @default(false)
  clientAccessExpiresAt DateTime?
  clientPinHash String?
  clientPinEnabled Boolean @default(false)
  clientPinCreatedAt DateTime?
  lastClientAccessAt DateTime?
  
  blocks      Block[]
  bookings    ServiceBooking[]
  notificationEvents NotificationEvent[]
  teamProjectMembers TeamProjectMember[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model NotificationEvent {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageId    String?
  page      Page?                 @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      NotificationEventType
  createdAt DateTime              @default(now())

  @@index([userId, createdAt])
  @@index([pageId, createdAt])
}

enum NotificationEventType {
  PROJECT_PORTAL_INVITE
  PROJECT_PORTAL_REINVITE
  PROJECT_PORTAL_COMMENT
  PROJECT_PORTAL_APPROVAL
  PROJECT_PORTAL_SUBMISSION
  TEAM_PROJECT_HUB_ASSIGNMENT
  TEAM_PROJECT_HUB_SUBMISSION
  TEAM_PROJECT_HUB_COMMENT
  TEAM_PROJECT_HUB_APPROVAL
  TEAM_PROJECT_HUB_CHANGES_REQUESTED
  TEAM_PROJECT_HUB_STAGE_MANAGER
  TEAM_PROJECT_HUB_ALLOWLIST
  MEDIA_KIT_REQUEST
}

enum PageCategory {
  FOOD_MENU
  SERVICE_MENU
  RESUME
  EPK
  GENERIC
  PROJECT_PORTAL
  TEAM_PROJECT_HUB
  INFLUENCER_MEDIA_KIT
  PORTFOLIO_CASE_STUDY
  PROPERTY_LISTING
}

enum TeamProjectMemberStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

model Block {
  id        String    @id @default(cuid())
  pageId    String
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      BlockType
  content   Json      // The actual data/configuration for the block
  order     Int       @default(0)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([pageId])
}

model TeamProjectMember {
  id           String                  @id @default(cuid())
  pageId        String
  page          Page                   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  email         String
  internalLabel String?
  status        TeamProjectMemberStatus @default(ACTIVE)
  role          TeamProjectMemberRole   @default(CONTRIBUTOR)
  inviteSentAt  DateTime?
  inviteAcceptedAt DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([pageId, email])
  @@index([pageId, status])
  @@index([pageId, userId])
}

enum BlockType {
  TEXT
  LINK
  IMAGE
  AUDIO
  VIDEO
  GRID
  CONTACT
  PRODUCT
  PROJECT_HEADER
  STATUS_SUMMARY
  TIMELINE
  TASK_BOARD
  FEEDBACK_LIST
  FEEDBACK_FORM
  COMMENT_THREAD
  DELIVERABLES
  BILLING_OVERVIEW
}

enum TeamProjectMemberRole {
  ADMIN
  CONTRIBUTOR
}

model ServiceBooking {
  id                     String               @id @default(cuid())
  pageId                 String
  page                   Page                 @relation(fields: [pageId], references: [id], onDelete: Cascade)
  status                 ServiceBookingStatus @default(PENDING)
  name                   String
  email                  String
  phone                  String?
  serviceId              String
  serviceName            String
  serviceDurationMinutes Int?
  bookingDate            String
  bookingTime            String
  bookingStartMinutes    Int
  bookingEndMinutes      Int
  message                String?
  ownerNotes             String?
  confirmedAt            DateTime?
  canceledAt             DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([pageId, bookingDate, status])
  @@index([pageId, createdAt])
}

enum ServiceBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  NO_SHOW
  CANCELED
  DECLINED
}
